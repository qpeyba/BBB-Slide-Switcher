{
  "manifest_version": 3,
  "name": "BBB Slide Switcher",
  "version": "1.0.0",
  "description": "Locally control presentation slides in Big Blue Button with optional presenter sync",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://*/bigbluebutton/*",
    "*://*.edu/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "BBB Slide Switcher"
  },
  "background": {
    "service_worker": "src/background/background.ts"
  },
  "content_scripts": [
    {
      "matches": ["*://*/bigbluebutton/*", "*://*.edu/*"],
      "js": ["src/content/content.ts"]
    }
  ]
}
